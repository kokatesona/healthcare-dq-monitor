# Database
DUCKDB_PATH=./data/healthcare.duckdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=healthcare_dq

# AWS
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=your-mlflow-artifacts-bucket

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_EXPERIMENT_NAME=healthcare-dq-monitor

# SageMaker
SAGEMAKER_ENDPOINT_NAME=healthcare-trust-scorer
SAGEMAKER_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT:role/SageMakerRole

# LangChain
OPENAI_API_KEY=your_openai_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=healthcare-dq-monitor

# LLM backend: "openai" or "bedrock"
LLM_BACKEND=openai
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False

# Anonymisation
ANON_SALT=dev-salt-change-in-prod
